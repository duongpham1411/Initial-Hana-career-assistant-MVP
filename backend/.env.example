APP_NAME=JobBuddy Voice Agent
APP_ENV=development
DATABASE_URL=sqlite:///./jobbuddy.db
FRONTEND_ORIGIN=http://localhost:5173

# Add real keys in backend/.env only. Never commit real secrets.
# AI_PROVIDER options: auto, gemini, openai, mock
AI_PROVIDER=auto

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
